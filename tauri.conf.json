{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "src",
    "distDir": "src",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Clock Widget",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "window": {
        "create": true,
        "startDragging": true,
        "close": true,
        "setAlwaysOnTop": true,
        "setFocus": true,
        "setSize": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "msi",
      "icon": [
        "icons/icon.ico"
      ],
      "identifier": "com.clockwidget.app"
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "title": "Clock Widget",
        "width": 336,
        "height": 296,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "x": 40,
        "y": 40,
        "focus": true
      }
    ]
  }
}
